{
  "compilerOptions": {

    "target": "ES2020",

    "useDefineForClassFields": true,

    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2020"
    ],

    "allowJs": false,

    "skipLibCheck": true,

    "esModuleInterop": true,

    "allowSyntheticDefaultImports": true,

    "strict": true,

    "forceConsistentCasingInFileNames": true,

    "module": "ESNext",

    "moduleResolution": "Node",

    "resolveJsonModule": true,

    "isolatedModules": true,

    "noEmit": true,

    "jsx": "react-jsx",

    "baseUrl": ".",

    "paths": {

      "@/*": [
        "./src/*"
      ],

      "@runtime/*": [
        "./runtime_os/*"
      ],

      "@apps/*": [
        "./runtime_apps/*"
      ],

      "@styles/*": [
        "./src/styles/*"
      ]
    }
  },

  "include": [

    "src",

    "runtime_os",

    "runtime_apps",

    "vite.config.ts",

    "tailwind.config.ts"
  ],

  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}